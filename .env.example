# =========================
# Pastry3D demo / production
# =========================

# Dominio público
PUBLIC_DOMAIN=pastry3d-sebas.duckdns.org

# PostgreSQL
POSTGRES_DB=pastry3d
POSTGRES_USER=pastry3d
POSTGRES_PASSWORD=change-me-postgres-password

DB_URL=jdbc:postgresql://postgres:5432/pastry3d
DB_USERNAME=pastry3d
DB_PASSWORD=change-me-postgres-password

# Backend
BACKEND_PORT=8080
JWT_SECRET=change-me-super-secret-jwt-key-minimum-64-characters
JWT_EXPIRATION_MS=86400000

# Admin inicial
APP_ADMIN_SEED_ENABLED=true
APP_ADMIN_EMAIL=admin@pastry3d.local
APP_ADMIN_PASSWORD=Admin12345

# SMTP
APP_MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-correo@gmail.com
MAIL_PASSWORD=tu-app-password-o-clave-smtp
MAIL_FROM=tu-correo@gmail.com
APP_MAIL_REGISTER_CODE_EXPIRATION_MINUTES=30

# Gemini
GEMINI_ENABLED=true
GEMINI_API_KEY=tu-api-key-gemini
GEMINI_MODEL=gemini-1.5-flash

# FairStack / proveedor externo experimental
FAIRSTACK_ENABLED=true
FAIRSTACK_BASE_URL=https://api.fairstack.ai/v1
FAIRSTACK_API_KEY=tu-api-key-fairstack
FAIRSTACK_GENERATE_PATH=/generations/threeD
FAIRSTACK_JOB_STATUS_PATH=/jobs/{jobId}
FAIRSTACK_MODEL=hunyuan-3d-rapid-t23d
FAIRSTACK_TIMEOUT_SECONDS=180
FAIRSTACK_CONFIRM=false
FAIRSTACK_MAX_COST_USD=3.00

# Storage local para GLB dentro del contenedor
STORAGE_UPLOADS=/opt/pastry3d/uploads/models

# CORS / URL pública
APP_CORS_ALLOWED_ORIGINS=https://pastry3d-sebas.duckdns.org,http://pastry3d-sebas.duckdns.org
APP_PUBLIC_BASE_URL=https://pastry3d-sebas.duckdns.org

# Frontend
VITE_API_BASE_URL=/api
# Tripo 3D generation
TRIPO_ENABLED=false
TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi
TRIPO_API_KEY=
TRIPO_MODEL_VERSION=v3.1-20260211
TRIPO_TEXTURE=true
TRIPO_PBR=true
TRIPO_TEXTURE_QUALITY=standard
TRIPO_GEOMETRY_QUALITY=standard
TRIPO_FACE_LIMIT=30000
TRIPO_AUTO_SIZE=true
TRIPO_EXPORT_UV=true
TRIPO_SMART_LOW_POLY=false
TRIPO_QUAD=false
TRIPO_NEGATIVE_PROMPT=low quality, blurry, deformed, broken geometry, extra objects, plate, table, hands, people, text, logo, watermark
TRIPO_TIMEOUT_SECONDS=180